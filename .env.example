# BINOVA Backend - Variables d'environnement
NODE_ENV=development
PORT=5000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/binova?retryWrites=true&w=majority

# JWT
JWT_SECRET=binova_jwt_secret_sgao_sarl_2026_very_long_secret_key
JWT_REFRESH_SECRET=binova_refresh_secret_sgao_sarl_2026_very_long_secret_key
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Email (Nodemailer / SendGrid)
EMAIL_FROM=noreply@binova.cm
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_PASS=your_sendgrid_api_key

# Firebase Admin SDK (FCM)
FIREBASE_PROJECT_ID=binova-sgao
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@binova-sgao.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Web Push (VAPID)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:admin@binova.cm

# Twilio (SMS OTP optionnel)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE=+12345678901

# Client URLs
CLIENT_URL=http://localhost:4200
ADMIN_URL=http://localhost:4300
RESET_PASSWORD_URL=http://localhost:4200/auth/reset-password

# IoT Simulator
IOT_SIMULATE_INTERVAL=30000
